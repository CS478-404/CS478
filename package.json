{
    "scripts": {
        "setup": "rm -f back/database.db && sqlite3 back/database.db < back/setup.sql",
        "data": "cd back && npm run data",
        "dev": "npm-run-all -p dev:client dev:server",
        "dev:client": "cd front && npm run dev",
        "dev:server": "cd back && nodemon --exec ts-node src/server.ts",
        "install:all": "npm install && cd front && npm install && cd ../back && npm install",
        "build": "cd front && npm run build"
    },
    "devDependencies": {
        "nodemon": "^3.1.14",
        "npm-run-all": "^4.1.5",
        "ts-node": "^10.9.2"
    }
}
